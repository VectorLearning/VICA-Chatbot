# --- Microsoft Bot Framework / Teams ---
# From Azure Bot resource (or Entra app registration used as the bot identity)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
# SingleTenant is required for new bots (multi-tenant deprecated July 31, 2025).
# MICROSOFT_APP_TENANT_ID is REQUIRED for SingleTenant.
MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_APP_TENANT_ID=

# --- Microsoft Graph (for reading channel history) ---
# Same tenant the Teams app lives in.
GRAPH_TENANT_ID=
# App registration with ChannelMessage.Read.All (application permission, admin-consented).
# Often this can be the SAME app as the bot above; if so, reuse those values.
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# --- Anthropic ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Set to "false" to disable. Requires admin to enable web search in the
# Claude Console (Settings → Privacy). $10 per 1000 searches.
ENABLE_WEB_SEARCH=true

# Path to the system prompt file (relative to the bot's working directory).
SYSTEM_PROMPT_PATH=system_prompt.md

# Folder of local skills (each .md file is one skill).
SKILLS_DIR=skills

# --- Bot behavior ---
CONTEXT_WINDOW_MINUTES=60
CONTEXT_MAX_MESSAGES=20

# --- Server ---
PORT=3978
